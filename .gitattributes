# Normalize line endings; keep platform launchers in their native ending.
* text=auto eol=lf

*.py    text eol=lf
*.sh    text eol=lf
*.mjs   text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Windows / Mac launchers
*.bat       text eol=crlf
*.ps1       text eol=crlf
*.command   text eol=lf

# Any stray binaries (should be gitignored, but be explicit)
*.db    binary
*.zip   binary
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.mp4   binary
*.mov   binary

{
  "name": "howiezz",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:recommend": "vitest run tests/recommend.test.js",
    "test:unit": "vitest run tests/*.test.js",
    "test:e2e": "cypress run",
    "test:e2e:watch": "cypress open",
    "test:a11y": "cypress run tests/e2e/accessibility.cy.js",
    "test:visual": "cypress run tests/visual/visual-regression.cy.js",
    "test:perf": "cypress run tests/e2e/performance.cy.js",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:ci": "npm run lint && npm run test:unit && npm run test:e2e",
    "install-hooks": "git config core.hooksPath hooks && chmod +x hooks/pre-push && echo 'Pre-push hook installed.'",
    "lint": "eslint api/ assets/ || true",
    "format": "prettier --write 'api/**/*.js' 'assets/**/*.js' 'tests/**/*.js' || true",
    "dev": "node scripts/dev-server.js",
    "build": "echo 'Build complete'",
    "deploy:vercel": "vercel deploy --prod",
    "deploy:netlify": "netlify deploy --prod",
    "analyze:ab": "node scripts/analyze-ab-test.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "axe-core": "^4.8.2",
    "axe-playwright": "^1.2.3",
    "cypress": "^13.17.0",
    "cypress-axe": "^1.7.0",
    "eslint": "^8.48.0",
    "jsdom": "^29.1.1",
    "lighthouse": "^11.4.0",
    "prettier": "^3.0.0",
    "vitest": "^4.1.8"
  }
}
